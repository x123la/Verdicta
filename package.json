{
  "name": "verdicta",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @verdicta/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "db:generate": "pnpm --filter @verdicta/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @verdicta/db drizzle-kit migrate"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
