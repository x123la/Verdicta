{
  "name": "@verdicta/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:app": "node ./scripts/build-electron.mjs && vite build",
    "build": "node ./scripts/build-electron.mjs && vite build && electron-builder",
    "sync:native": "electron-builder install-app-deps",
    "start:prod": "electron . --no-sandbox",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@tanstack/react-query": "^5.59.0",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@verdicta/ai": "workspace:*",
    "@verdicta/core": "workspace:*",
    "@verdicta/db": "workspace:*",
    "@verdicta/legal": "workspace:*",
    "@verdicta/shared": "workspace:*",
    "@verdicta/ui": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.35.3",
    "electron": "^33.0.2",
    "eventsource-parser": "^3.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.453.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.verdicta.desktop",
    "productName": "Verdicta",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
